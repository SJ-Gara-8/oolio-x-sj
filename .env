# Demo defaults for local `go run`, godotenv, and Docker Compose.
# Replace API_KEY (and other values) for real deployments; do not commit secrets to a public fork.

# --- HTTP server ---
PORT=8080
API_KEY=apitest

# Logging: text (default) or JSON for Docker / log aggregators
LOG_JSON=0
# Alternative to LOG_JSON=1:
# LOG_FORMAT=json

# debug | info | warn | error
LOG_LEVEL=info

# Graceful shutdown budget after SIGINT/SIGTERM
SHUTDOWN_TIMEOUT_SEC=30

# net/http.Server timeouts (protect against slow clients / slowloris)
READ_HEADER_TIMEOUT_SEC=5
READ_TIMEOUT_SEC=15
WRITE_TIMEOUT_SEC=60
IDLE_TIMEOUT_SEC=120

# chi per-request handler timeout (should be <= WRITE_TIMEOUT_SEC in normal setups)
CHI_REQUEST_TIMEOUT_SEC=60

# POST /order JSON body limit (bytes)
MAX_BODY_BYTES=1048576

# Product image CDN base (trailing slash optional)
IMAGE_BASE_URL=https://orderfoodonline.deno.dev/public/images/

# --- Coupon corpora (challenge): download URL + local filenames for .gz and .idx cache ---
COUPON_1_URL=https://orderfoodonline-files.s3.ap-southeast-2.amazonaws.com/couponbase1.gz
COUPON_1_GZ=couponbase1.gz
COUPON_1_IDX=couponbase1.idx

COUPON_2_URL=https://orderfoodonline-files.s3.ap-southeast-2.amazonaws.com/couponbase2.gz
COUPON_2_GZ=couponbase2.gz
COUPON_2_IDX=couponbase2.idx

COUPON_3_URL=https://orderfoodonline-files.s3.ap-southeast-2.amazonaws.com/couponbase3.gz
COUPON_3_GZ=couponbase3.gz
COUPON_3_IDX=couponbase3.idx
